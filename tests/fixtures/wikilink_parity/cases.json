      "page_slug": "Good--Slug",
      "expected_page_slug": "good-slug",
      "expected_slugs": [],
      "resolve": {},
      "expected_body_canonicalize": "Docs show `[[Foo Bar]]` in code only.",
      "expected_body_coerce": "Docs show `[[Foo Bar]]` in code only.",
      "expect_coerce_changed": true
    },
    {
      "id": "code-only-collision-does-not-refuse",
      "body": "`[[foo-bar]] and [[foo--bar]]` collide in code only.",
      "page_slug": "Good--Slug",
      "expected_page_slug": "good-slug",
      "expected_slugs": [],
      "resolve": {},
      "expected_body_canonicalize": "`[[foo-bar]] and [[foo--bar]]` collide in code only.",
      "expected_body_coerce": "`[[foo-bar]] and [[foo--bar]]` collide in code only.",
      "expect_coerce_changed": true
    }
  ]
}
