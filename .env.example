# Copy to .env and fill in the providers you actually use.
# setup.sh does this automatically if .env is missing.
#
# No key is strictly required by the code (Settings defaults to empty) — set
# the ones for the providers you run. The standing production model is
# deepseek-v4-flash (DEEPSEEK_API_KEY). Anthropic models were retired from
# the pool 2026-07-21; engine support remains, so the key still works if
# an anthropic model is ever re-added.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
QWEN_US_API_KEY=
XAI_GROK_API_KEY=
OLLAMA_API_KEY=
DEEPSEEK_API_KEY=
ZAI_API_KEY=

# Phase 1 — patience before first byte (covers thinking-model warmup).
LLM_TIMEOUT_SECONDS=120
# Phase 2 — silence detection after first chunk arrives (mid-generation hang).
LLM_INACTIVITY_TIMEOUT_SECONDS=60
